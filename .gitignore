# =============================================================================
# Rust / Cargo
# =============================================================================
# 编译输出目录（workspace 级统一忽略）
/target/
**/.rustc_info.json

# 备份文件
**/*.rs.bk
*.pdb

# 特定平台的可执行文件
*.exe
*.dll
*.so
*.dylib
*.bin
*.cmd

# 注意：Cargo.lock 对于二进制项目必须提交，因此不忽略
# 注意：.cargo/ 包含项目配置（如 audit.toml），因此不忽略

# =============================================================================
# Foundry / Solidity
# =============================================================================
# 合约编译输出
contracts/cache/
contracts/out/
contracts/broadcast/
contracts/foundry.lock
gas_snapshot.json

# =============================================================================
# Web / WASM (Leptos)
# =============================================================================
# wasm-pack 输出目录
apps/web/pkg/

# Leptos CSR 构建输出
target/site/

# Node 相关
node_modules/
dist/
build/

